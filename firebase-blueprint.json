{
  "entities": {
    "public_islands": {
      "title": "Public Island",
      "description": "A shared island that can be anchored by other users.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "cards": { "type": "array" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "isPublic": { "type": "boolean" },
        "downloads": { "type": "number" },
        "publishedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "authorId", "isPublic"]
    },
    "published_archipelagos": {
      "title": "Published Archipelago",
      "description": "A shared archipelago of islands that can be imported by other users.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "islandCount": { "type": "number" },
        "islands": { "type": "array" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "isPublic": { "type": "boolean" },
        "downloads": { "type": "number" },
        "publishedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "authorId", "isPublic", "islands"]
    },
    "users": {
      "title": "User Profile",
      "description": "Information about the authenticated user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "URL to the user's profile photo." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." },
        "last_active": { "type": "string", "format": "date-time", "description": "Last time the user was active." },
        "islands": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "color_score": { "type": "number", "minimum": 0, "maximum": 100 },
              "cards": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "front": { "type": "string" },
                    "back": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile data."
    },
    "/published_islands/{islandId}": {
      "schema": "public_islands",
      "description": "Shared islands available for discovery."
    },
    "/published_archipelagos/{archipelagoId}": {
      "schema": "published_archipelagos",
      "description": "Shared archipelagos available for discovery."
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isIslandOwner() {
      return isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    function ownsIsland() {
      return isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    function isCardOwner() {
      return isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    function ownsCard() {
      return isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    function isCollaboratorOnIsland() {
      return isSignedIn() &&
             resource.data.isCollaborative == true &&
             request.auth.uid in resource.data.collaborators;
    }

    function isIslandCollaboratorByDoc(islandId) {
      let island = get(/databases/$(database)/documents/islands/$(islandId));
      return isSignedIn() &&
             island.data.isCollaborative == true &&
             (island.data.ownerId == request.auth.uid ||
              request.auth.uid in island.data.collaborators);
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256;
    }

    function isValidUserCreate(data, userId) {
      return isValidUser(data) && data.uid == userId;
    }

    function isValidPublicIsland(data) {
      return data.keys().hasAll(['id', 'name', 'authorId', 'isPublic']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.authorId == request.auth.uid;
    }

    function isValidPublishedArchipelago(data) {
      return data.keys().hasAll(['id', 'name', 'authorId', 'isPublic', 'islands']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.authorId == request.auth.uid &&
             data.islands is list && data.islands.size() <= 50;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUserCreate(incoming(), userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Admin-managed top-level content collections
    match /islands/{islandId} {
      allow create: if isIslandOwner() || isAdmin();
      // Read uses a weaker check (no isCollaborative guard) so that
      // where('collaborators','array-contains',uid) list queries are accepted.
      // Firestore rejects a list query if the rule has conditions not implied
      // by the filter; checking collaborators alone is enough here.
      allow read: if ownsIsland() || (isSignedIn() && request.auth.uid in resource.data.collaborators) || isAdmin();
      allow update: if ownsIsland() || isCollaboratorOnIsland() || isAdmin();
      allow delete: if ownsIsland() || isAdmin();
    }

    match /cards/{cardId} {
      allow create: if isCardOwner() || isIslandCollaboratorByDoc(request.resource.data.islandId) || isAdmin();
      allow read: if ownsCard() || isIslandCollaboratorByDoc(resource.data.islandId) || isAdmin();
      allow update: if ownsCard() || isIslandCollaboratorByDoc(resource.data.islandId) || isAdmin();
      allow delete: if ownsCard() || isIslandCollaboratorByDoc(resource.data.islandId) || isAdmin();
    }

    // Collaborative archipelagos (top-level collection, separate from user-embedded arrays)
    match /archipelagos/{archipelagoId} {
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      // Same reasoning as islands: read omits isCollaborative guard so list queries work.
      allow read: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid ||
        request.auth.uid in resource.data.collaborators ||
        isAdmin()
      );
      allow update: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid ||
        (resource.data.isCollaborative == true && request.auth.uid in resource.data.collaborators) ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /adminStats/{docId} {
      allow read: if isAdmin();
    }

    match /globalAnnouncements/{announcementId} {
      allow create, update, delete: if isAdmin();
      allow read: if isSignedIn();
    }

    // Profiles Collection for social features and leaderboards
    match /profiles/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Friendships Collection for mutual social relationships
    match /friendships/{friendshipId} {
      // Read: Anyone in the relationship can read it
      allow read: if request.auth != null && request.auth.uid in resource.data.users;

      // Create (Send Request): 
      // 1. You must be in the users array
      // 2. You must be the requesterId
      // 3. The status MUST be 'pending'
      allow create: if request.auth != null 
                    && request.auth.uid in request.resource.data.users
                    && request.auth.uid == request.resource.data.requesterId
                    && request.resource.data.status == 'pending'
                    && request.resource.data.users.size() == 2;
                    
      // Update (Accept Request):
      // 1. You must be in the existing users array
      // 2. You must NOT be the requester (you can't accept your own request)
      // 3. You can only change the status to 'accepted'
      allow update: if request.auth != null 
                    && request.auth.uid in resource.data.users
                    && request.auth.uid != resource.data.requesterId
                    && request.resource.data.status == 'accepted'
                    // Prevent tampering with existing data
                    && request.resource.data.users == resource.data.users
                    && request.resource.data.requesterId == resource.data.requesterId;

      // Delete (Reject Request / Unfriend / Cancel Request):
      // Anyone in the relationship can delete the document
      allow delete: if request.auth != null 
                    && request.auth.uid in resource.data.users;
    }

    // 2. Published Islands Discovery
    match /published_islands/{islandId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidPublicIsland(request.resource.data);
      allow update: if isSignedIn() && resource.data.authorId == request.auth.uid && isValidPublicIsland(request.resource.data);
      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // 3. Published Archipelagos Discovery
    match /published_archipelagos/{archipelagoId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidPublishedArchipelago(request.resource.data);
      allow update: if isSignedIn() && resource.data.authorId == request.auth.uid && isValidPublishedArchipelago(request.resource.data);
      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // 4. Community Q&A — persistent peer learning questions and answers
    match /questions/{questionId} {
      // Privacy enforced at query time via visibleTo array-contains
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.askerId == request.auth.uid &&
        request.resource.data.status == 'open' &&
        request.resource.data.acceptedAnswerId == null &&
        request.resource.data.answerCount == 0 &&
        request.resource.data.frontText is string &&
        request.resource.data.frontText.size() <= 500;
      allow update: if isSignedIn() && (
        // Asker can change visibility, status, acceptedAnswerId
        resource.data.askerId == request.auth.uid
        ||
        // Anyone can increment answerCount + lastActivityAt when posting an answer
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['answerCount', 'lastActivityAt']) &&
          request.resource.data.answerCount == resource.data.answerCount + 1
        )
        ||
        // Anyone can write an AI hint to a zero-answer open question
        (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['aiHint', 'aiHintGeneratedAt']) &&
          resource.data.answerCount == 0
        )
      );
      allow delete: if isSignedIn() && resource.data.askerId == request.auth.uid;

      // Answers sub-collection
      match /answers/{answerId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() &&
          request.resource.data.helperId == request.auth.uid &&
          request.resource.data.voteCount == 0 &&
          request.resource.data.isAccepted == false &&
          request.resource.data.bodyText is string &&
          request.resource.data.bodyText.size() <= 2000;
        allow update: if isSignedIn() && (
          // Author can edit their answer body
          resource.data.helperId == request.auth.uid
          ||
          // Anyone can vote (upvoterIds map + voteCount); delta must be exactly ±1
          (request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['upvoterIds', 'voteCount', 'updatedAt']) &&
           (request.resource.data.voteCount == resource.data.voteCount + 1 ||
            request.resource.data.voteCount == resource.data.voteCount - 1))
          ||
          // Asker can accept (isAccepted + updatedAt)
          (
            request.resource.data.isAccepted == true &&
            resource.data.isAccepted == false &&
            get(/databases/$(database)/documents/questions/$(questionId)).data.askerId
              == request.auth.uid
          )
        );
        allow delete: if isSignedIn() && resource.data.helperId == request.auth.uid;

        // Comments sub-sub-collection
        match /comments/{commentId} {
          allow read: if isSignedIn();
          allow create: if isSignedIn() &&
            request.resource.data.authorId == request.auth.uid &&
            request.resource.data.bodyText is string &&
            request.resource.data.bodyText.size() <= 500;
          allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
        }
      }
    }

    // 5a. Named test definitions — private per-user
    match /tests/{testId} {
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // 5b. Test Mode sessions — private per-user exam records
    match /test-sessions/{sessionId} {
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // 5. User reputation — cross-user increment for vote/accept rewards
    match /user_reputation/{userId} {
      allow read: if isSignedIn();
      // Any signed-in user may update reputation (required for cross-user vote/accept rewards).
      // Writes are constrained to the three tracked counters only.
      allow write: if isSignedIn() &&
        request.resource.data.keys().hasOnly(['totalVotesReceived', 'totalAnswers', 'totalAccepted']);
    }
  }
}
